Algoritmo ejercici18
	//Juan Diego Rios Giraldo
	//Pedir un n·mero e indicar si es positivo o negativo.
	
	//DEFINICIėN DE VARIABLES 
	
	Definir num Como Real;
	
	//ENTRADA
	Escribir "Ingrese su n·mero";
	Leer num;
	
	//PROCESO Y SALIDA
	
	si num <= 0 Entonces
		si num == 0 Entonces
			Escribir "Su n·mero es neutro";
		SiNo
			Escribir "Su n·mero es negativo";
		FinSi
		
	SiNo
		Escribir "Su n·mero es positivo";
	FinSi
	
	
FinAlgoritmo
