Proceso ejercicio14
	//Juan Diego Rios Giraldo
	// Pedir el radio de una circunferencia y calcular su longitud. 
	
	//DEFINICIėN DE VARIABLES 
	
	Definir R Como Real;
	Definir L Como Real;
	Definir PI2 Como Real;
	PI2 <- 3.1416;
	
	
	//ENTRADA
	
	Escribir "Ingrese el radio de su circunferencia";
	Leer R;
	
	//PROCESO 
	
	L <- PI2*2*R;
	
	//SALIDA
	
	Escribir "La longitud calculada con su radio ",R," es ig·al a ",L;
	
FinProceso