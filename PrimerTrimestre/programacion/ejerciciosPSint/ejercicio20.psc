Proceso ejercicio20
	//Juan Diego Rios Giraldo
	//Pedir dos números y decir cuál es el mayor
	
	// DEFINICION DE VARIABLES
	
	Definir numA Como Real;
	Definir numB como Real;
	
	// ENTRADA
	
	Escribir "Ingrese el numero A";
	Leer numA;
	Escribir "Ingrese el numero B";
	Leer numB;
	
	// PROCESOS
	
	si (numA > numB) Entonces
		Escribir "El numero ",numA," es mayor que el numero ",numB;
	SiNo
		Escribir "El numero ",numB," es mayor al numero ",numA;
	FinSi
	
FinProceso