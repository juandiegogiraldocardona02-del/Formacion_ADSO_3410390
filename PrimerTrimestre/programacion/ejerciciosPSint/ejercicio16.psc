	// Calcular el Šrea de un rectŠngulo de lados X e Y.
	
	//DEFINICI”N DE VARIABLES
	
	Definir ladoX Como Entero;
	Definir ladoY Como Entero;
	Definir area Como Real;
	
	//ENTRADA
	
	Escribir "Ingrese el valor de X";
	Leer ladoX;
	Escribir "Ingrese el valo de Y";
