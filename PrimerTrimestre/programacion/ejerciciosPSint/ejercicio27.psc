Algoritmo ejercicio27
	
	//Juan Diego Rios Giraldo
	// Pedir un nºmero y decir si es par o impar.
	
	//DEFINICION DE VARIABLES
	
	Definir num Como Real;
	
	
	//ENTRADA
	
	Escribir "Ingrese un numero";
	Leer num;
	
	//PROCESO Y SALIDA
	
	si num%2 == 0 Entonces
		Escribir "Su numero es par";
	SiNo
		Escribir "Su numero es impar";
	FinSi
	
FinAlgoritmo