Proceso ejercicio13
	//Juan Diego Rios Giraldo
	// Pedir el radio de un círculo y calcular su área. A=PI*r^2.
	
	
	//DEFINICIÓN DE VARIABLES 
	
	Definir R Como Real;
	Definir A Como Real;
	Definir PI2 como Real;
	PI2 <- 3.1416;
	
	//ENTRADA
	
	Escribir "Ingrese el valor del radio de su circulo";
	Leer R;
	
	//PROCESO 
	
	A<-PI2*R^2;
	
	//SALIDA
	
	Escribir "El area de su circulo con radio ",R," es igúal a ",A;
	
FinProceso